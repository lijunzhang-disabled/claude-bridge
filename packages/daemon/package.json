{
  "name": "@claude-bridge/daemon",
  "version": "1.0.0",
  "description": "Claude Bridge daemon — message loop, channel orchestration",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "claude-bridge": "./dist/main.js"
  },
  "files": ["dist"],
