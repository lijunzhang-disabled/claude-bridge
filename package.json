{
  "name": "claude-bridge",
  "version": "1.0.0",
  "description": "Bridge chat platforms (WeChat, Telegram, Discord, ...) to local Claude Code",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/channel-wechat",
    "packages/channel-telegram",
    "packages/channel-lark",
    "packages/daemon"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "dev": "tsc -b --watch",
    "postinstall": "npm run build",
    "start": "node packages/daemon/dist/main.js",
    "setup": "node packages/daemon/dist/main.js setup",
    "daemon": "bash scripts/daemon.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["claude-code", "claude", "bridge", "chat", "wechat", "telegram", "lark", "feishu", "discord", "skill"],
  "author": "lijunzhang-disabled",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lijunzhang-disabled/claude-bridge.git"
  }
}
